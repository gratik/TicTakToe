@* Game mode, difficulty selectors, and new-game button. *@
<div class="controls">
    <div class="controls-selectors">
        <div class="control-group">
            <label for="mode-select">Mode</label>
            <select id="mode-select" value="@Mode" @onchange="HandleModeChange">
                <option value="@GameMode.PvP">Player vs Player</option>
                <option value="@GameMode.PvC">Player vs Computer</option>
                <option value="@GameMode.CvC">Computer vs Computer</option>
            </select>
        </div>
        <div class="control-group">
            <label for="diff-select">Difficulty</label>
            <select id="diff-select" value="@Difficulty" @onchange="HandleDifficultyChange"
                    disabled="@(Mode == GameMode.PvP)">
                <option value="@Difficulty.Easy">Easy</option>
                <option value="@Difficulty.Medium">Medium</option>
                <option value="@Difficulty.Hard">Hard</option>
            </select>
        </div>
        <div class="control-group">
            <label for="board-size-select">Board size</label>
            <select id="board-size-select" value="@BoardSize" @onchange="HandleBoardSizeChange">
                <option value="3">3×3 (three in a row)</option>
                <option value="4">4×4 (four in a row)</option>
                <option value="5">5×5 (five in a row)</option>
            </select>
        </div>
    </div>
    <button class="btn btn-primary" @onclick="OnNewGame">New Game</button>
    @if (Mode == GameMode.PvC)
    {
        <button class="btn btn-outline" @onclick="() => OnHintRequested.InvokeAsync()" aria-label="Show AI hint">Hint</button>
    }
    <details class="customization-details">
        <summary>Customise players &amp; AI</summary>
        <div class="player-customization">
            <div class="player-custom-group">
                <label for="player-x-name">X Name</label>
                <input id="player-x-name" value="@PlayerXName" @oninput="HandlePlayerXNameInput" maxlength="12" class="name-input" />
                <input id="player-x-color" type="color" value="@PlayerXColor" @oninput="HandlePlayerXColorInput" class="color-input" title="X colour" />
            </div>
            <div class="player-custom-group">
                <label for="player-o-name">O Name</label>
                <input id="player-o-name" value="@PlayerOName" @oninput="HandlePlayerONameInput" maxlength="12" class="name-input" />
                <input id="player-o-color" type="color" value="@PlayerOColor" @oninput="HandlePlayerOColorInput" class="color-input" title="O colour" />
            </div>
            <div class="player-custom-group">
                <label>
                    <input id="ai-visualization-toggle" type="checkbox" checked="@ShowAiVisualization" @onchange="OnAiVisualizationChangedHandler" />
                    AI overlay
                </label>
                @if (ShowAiVisualization)
                {
                    <select id="ai-visualization-mode" value="@VisualizationMode" @onchange="OnVisualizationModeChangedHandler">
                        <option value="Heatmap">Heatmap</option>
                        <option value="Step">Step</option>
                    </select>
                    @if (VisualizationMode == "Step")
                    {
                        <div style="display:flex; gap:0.25rem; align-items:center;">
                            <button class="btn btn-ghost" style="padding:0.15rem 0.5rem; font-size:0.8rem;" @onclick="OnStepPrev" aria-label="Previous step">&#8592;</button>
                            <span style="font-size:0.85rem;">@StepIndexDisplay</span>
                            <button class="btn btn-ghost" style="padding:0.15rem 0.5rem; font-size:0.8rem;" @onclick="OnStepNext" aria-label="Next step">&#8594;</button>
                            <button class="btn btn-ghost" style="padding:0.15rem 0.5rem; font-size:0.8rem;" @onclick="OnStepPlayPause" aria-label="Play/Pause">@PlayPauseIcon</button>
                        </div>
                    }
                }
            </div>
        </div>
    </details>
</div>

@code {
    /// <summary>The currently selected game mode.</summary>
    [Parameter] public GameMode Mode { get; set; }

    /// <summary>The currently selected difficulty.</summary>
    [Parameter] public Difficulty Difficulty { get; set; }

    /// <summary>The currently selected board size.</summary>
    [Parameter] public int BoardSize { get; set; }

    /// <summary>Raised when the game mode changes.</summary>
    [Parameter] public EventCallback<GameMode> OnModeChanged { get; set; }

    /// <summary>Raised when the difficulty changes.</summary>
    [Parameter] public EventCallback<Difficulty> OnDifficultyChanged { get; set; }

    /// <summary>Raised when the board size changes.</summary>
    [Parameter] public EventCallback<int> OnBoardSizeChanged { get; set; }

    /// <summary>Raised when the user requests a new game.</summary>
    [Parameter] public EventCallback OnNewGame { get; set; }

    /// <summary>Raised when the user requests a hint (PvC only).</summary>
    [Parameter] public EventCallback OnHintRequested { get; set; }

    [Parameter] public string PlayerXName { get; set; } = "Player X";
    [Parameter] public string PlayerOName { get; set; } = "Player O";
    [Parameter] public string PlayerXColor { get; set; } = "#1976d2";
    [Parameter] public string PlayerOColor { get; set; } = "#d32f2f";

    [Parameter] public EventCallback<string> OnPlayerXNameChanged { get; set; }
    [Parameter] public EventCallback<string> OnPlayerONameChanged { get; set; }
    [Parameter] public EventCallback<string> OnPlayerXColorChanged { get; set; }
    [Parameter] public EventCallback<string> OnPlayerOColorChanged { get; set; }

    [Parameter] public bool ShowAiVisualization { get; set; }
    [Parameter] public EventCallback<bool> OnShowAiVisualizationChanged { get; set; }

    [Parameter] public string VisualizationMode { get; set; } = "Heatmap";
    [Parameter] public EventCallback<string> OnVisualizationModeChanged { get; set; }

    [Parameter] public int StepIndex { get; set; }
    [Parameter] public EventCallback<int> OnStepIndexChanged { get; set; }

    [Parameter] public bool StepPlay { get; set; }
    [Parameter] public EventCallback<bool> OnStepPlayChanged { get; set; }

    private async Task HandleModeChange(ChangeEventArgs e)
    {
        if (Enum.TryParse<GameMode>(e.Value?.ToString(), out var mode))
            await OnModeChanged.InvokeAsync(mode);
    }

    private async Task HandleDifficultyChange(ChangeEventArgs e)
    {
        if (Enum.TryParse<Difficulty>(e.Value?.ToString(), out var diff))
            await OnDifficultyChanged.InvokeAsync(diff);
    }

    private async Task HandleBoardSizeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
            await OnBoardSizeChanged.InvokeAsync(size);
    }

    private async Task OnVisualizationModeChangedHandler(ChangeEventArgs e)
    {
        var mode = e.Value?.ToString() ?? "Heatmap";
        await OnVisualizationModeChanged.InvokeAsync(mode);
    }

    private async Task OnStepPrev() => await OnStepIndexChanged.InvokeAsync(StepIndex - 1);
    private async Task OnStepNext() => await OnStepIndexChanged.InvokeAsync(StepIndex + 1);
    private async Task OnStepPlayPause() => await OnStepPlayChanged.InvokeAsync(!StepPlay);

    private string StepIndexDisplay => (StepIndex + 1).ToString();
    private string PlayPauseIcon => StepPlay ? "⏸" : "▶";

    private async Task HandlePlayerXNameInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        await OnPlayerXNameChanged.InvokeAsync(value);
    }

    private async Task HandlePlayerXColorInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "#1976d2";
        await OnPlayerXColorChanged.InvokeAsync(value);
    }

    private async Task HandlePlayerONameInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        await OnPlayerONameChanged.InvokeAsync(value);
    }

    private async Task HandlePlayerOColorInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "#d32f2f";
        await OnPlayerOColorChanged.InvokeAsync(value);
    }

    private async Task OnAiVisualizationChangedHandler(ChangeEventArgs e)
    {
        if (e.Value is bool b)
            await OnShowAiVisualizationChanged.InvokeAsync(b);
        else if (e.Value is string s && bool.TryParse(s, out var parsed))
            await OnShowAiVisualizationChanged.InvokeAsync(parsed);
        else
            await OnShowAiVisualizationChanged.InvokeAsync(!ShowAiVisualization);
    }
}

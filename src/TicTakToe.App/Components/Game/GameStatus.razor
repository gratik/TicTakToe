@* Displays the current turn or final game result. *@
<div class="status @StatusClass">
    <span class="player-avatar" style="background:@PlayerXColor; opacity:@(Engine.CurrentPlayer == Player.X ? 1 : 0.5)">@GetInitials(PlayerXName)</span>
    <span class="status-icon">@StatusIcon</span>
    <span class="status-text">@StatusText</span>
    <span class="player-avatar" style="background:@PlayerOColor; opacity:@(Engine.CurrentPlayer == Player.O ? 1 : 0.5)">@GetInitials(PlayerOName)</span>
</div>

@code {
    /// <summary>The game engine providing current state.</summary>

    [Parameter, EditorRequired] public IGameEngine Engine { get; set; } = default!;
    [Parameter] public string PlayerXName { get; set; } = "Player X";
    [Parameter] public string PlayerOName { get; set; } = "Player O";
    [Parameter] public string PlayerXColor { get; set; } = "#1976d2";
    [Parameter] public string PlayerOColor { get; set; } = "#d32f2f";
    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ');
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpper();
    }

    private string StatusText => Engine.Result switch
    {
        GameResult.XWins => $"{PlayerXName} wins! 🎉",
        GameResult.OWins => $"{PlayerOName} wins! 🎉",
        GameResult.Draw  => "It's a draw!",
        _ => Engine.Mode == GameMode.CvC
                ? $"{(Engine.CurrentPlayer == Player.X ? PlayerXName : PlayerOName)} is thinking…"
                : $"{PlayerLabel(Engine.CurrentPlayer)}'s turn"
    };

    private string StatusIcon => Engine.Result switch
    {
        GameResult.XWins or GameResult.OWins => "🏆",
        GameResult.Draw => "🤝",
        _ => Engine.CurrentPlayer == Player.X ? "✖️" : "⭕"
    };

    private string StatusClass => Engine.Result switch
    {
        GameResult.XWins => "status-win status-x",
        GameResult.OWins => "status-win status-o",
        GameResult.Draw  => "status-draw",
        _ => "status-playing"
    };

    private string PlayerLabel(Player p) => Engine.Mode switch
    {
        GameMode.PvP => p == Player.X ? PlayerXName : PlayerOName,
        GameMode.PvC => p == Player.X ? PlayerXName : PlayerOName,
        _ => p == Player.X ? PlayerXName : PlayerOName
    };
}

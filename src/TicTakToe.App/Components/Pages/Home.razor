@page "/"
@rendermode InteractiveServer
@inject IGameEngine Engine
@inject IStatsService StatsService
@inject ILogger<Home> Logger
@inject TicTakToe.App.Core.Services.Interfaces.IAiPlayer AiPlayer
@inject IJSRuntime js
@implements IDisposable

<PageTitle>Tic-Tac-Toe</PageTitle>

<link href="css/result-banner.css" rel="stylesheet" />
@if (Engine.Result == GameResult.XWins || Engine.Result == GameResult.OWins || Engine.Result == GameResult.Draw)
{
    <div class="result-banner @ResultBannerClass" @onclick="StartNewGame" tabindex="0" role="status" aria-live="polite">
        <span class="result-text">
            @(Engine.Result == GameResult.XWins ? $"{_playerXName} wins!" : Engine.Result == GameResult.OWins ? $"{_playerOName} wins!" : "It's a draw!")
        </span>
        <button class="btn btn-primary play-again" @onclick:stopPropagation="true" @onclick="StartNewGame">Play Again</button>
    </div>
}
<div class="game-layout">
    <div class="game-column">
        <div class="card game-card @(ShowShake ? "shake" : null)">
            <div class="camera-overlay @CameraOverlayClass" aria-hidden="@(!CameraOverlayActive)">
                <span class="camera-overlay-text">@(_cameraOverlayText ?? string.Empty)</span>
            </div>
            <div class="camera-cue" aria-live="polite">
                @(_cameraCueMessage ?? (_mode == GameMode.CvC ? "CvC cameras are ready." : "Switch to CvC to activate cinematic cues."))
            </div>
            <GameStatus Engine="Engine" PlayerXName="@_playerXName" PlayerOName="@_playerOName" PlayerXColor="@_playerXColor" PlayerOColor="@_playerOColor" />
            <GameBoard Engine="Engine"
                       OnHumanMove="HandleHumanMove"
                       HintIndex="@_hintIndex"
                       PlayerXColor="@_playerXColor"
                       PlayerOColor="@_playerOColor"
                       ForkCells="@_forkCells"
                       BlockCells="@_blockCells"
                       DrawCells="@_drawCells"
                       ShowResetAnim="@_showResetAnim"
                       AiMoveEvaluations="_showAiVisualization ? _aiMoveEvaluations : null"
                       VisualizationMode="_visualizationMode"
                       StepIndex="_stepIndex" />
            @if (_hintIndex.HasValue && _mode == GameMode.PvC && Engine.Result == GameResult.InProgress)
            {
                <div class="hint-explanation" style="margin-top:0.5rem; color:#2a7; font-size:1rem;">
                    <strong>Hint:</strong> Cell @(_hintIndex.Value + 1) — @_hintExplanation
                    <button class="btn btn-link" style="margin-left:1rem;" @onclick="ClearHint">Clear</button>
                </div>
            }
            <GameControls Mode="_mode"
                          Difficulty="_difficulty"
                          BoardSize="_boardSize"
                          OnNewGame="StartNewGame"
                          OnModeChanged="HandleModeChanged"
                          OnDifficultyChanged="HandleDifficultyChanged"
                          OnBoardSizeChanged="HandleBoardSizeChanged"
                          OnHintRequested="HandleHintRequested"
                          PlayerXName="@_playerXName"
                          PlayerOName="@_playerOName"
                          PlayerXColor="@_playerXColor"
                          PlayerOColor="@_playerOColor"
                          OnPlayerXNameChanged="HandlePlayerXNameChanged"
                          OnPlayerONameChanged="HandlePlayerONameChanged"
                          OnPlayerXColorChanged="HandlePlayerXColorChanged"
                          OnPlayerOColorChanged="HandlePlayerOColorChanged"
                          ShowAiVisualization="@_showAiVisualization"
                          OnShowAiVisualizationChanged="HandleShowAiVisualizationChanged"
                          VisualizationMode="@_visualizationMode"
                          OnVisualizationModeChanged="HandleVisualizationModeChanged"
                          StepIndex="@_stepIndex"
                          OnStepIndexChanged="HandleStepIndexChanged"
                          StepPlay="@_stepPlay"
                          OnStepPlayChanged="HandleStepPlayChanged" />
        </div>
    </div>
    <div class="stats-column">
        <StatsPanel @ref="_statsPanel" ActiveMode="_mode" OnReset="StateHasChanged" />
    </div>
</div>

@code {
    private GameMode _mode = GameMode.PvP;
    private Difficulty _difficulty = Difficulty.Medium;
    private int _boardSize = 3;

    private bool ShowShake { get; set; }
    private IReadOnlyList<AiMoveEvaluation>? _aiMoveEvaluations;
    private bool _showResetAnim;
    private string _visualizationMode = "Heatmap";
    private int _stepIndex = 0;
    private bool _stepPlay = false;
    private bool _showAiVisualization = false;
    private string _playerXName = "Player X";
    private string _playerOName = "Player O";

    private static readonly string[] AiNames =
    [
        "AIDEN", "NEXUS", "CIPHER", "ORION", "VERTEX",
        "AXIOM", "PULSE", "ECHO", "NOVA", "ZENITH",
        "QUBIT", "LYRA", "TITAN", "VEGA", "HELIX",
        "ARGO", "SYREN", "OBERON", "KIRA", "DRACO"
    ];

    private static string PickAiName(Random rng, string exclude) 
    {
        var name = AiNames[rng.Next(AiNames.Length)];
        while (name == exclude)
            name = AiNames[rng.Next(AiNames.Length)];
        return name;
    }
    private string _playerXColor = "#1976d2";
    private string _playerOColor = "#d32f2f";
    private int? _hintIndex;
    private string? _hintExplanation;

    private StatsPanel? _statsPanel;
    private bool _resultPersisted;
    private BoardConfiguration BoardConfig => new(_boardSize, _boardSize);

    // Animation highlight state
    private IReadOnlyList<int>? _forkCells;
    private IReadOnlyList<int>? _blockCells;
    private IReadOnlyList<int>? _drawCells;

    // CvC speed acceleration
    private const int CvcStartDelay = 600;
    private const int CvcMinDelay = 30;
    private const double CvcDecayFactor = 0.75;
    private int _cvcMoveDelay = CvcStartDelay;

    private const int CameraFlashDurationMs = 1400;
    private const int VictoryHoldDurationMs = 1000;
    private const int DramaticHoldBonusMs = 600;

    private bool _dramaticWinPending;

    private readonly TicTakToe.App.Core.Services.CvcScheduler _cvcScheduler = new();
    private readonly TicTakToe.App.Core.Services.CameraOverlayManager _cameraOverlay = new();

    private string CameraOverlayClass => _cameraOverlay.ShowCameraFlash ? "active flash" : _cameraOverlay.ShowVictoryHold ? "active hold" : string.Empty;
    private bool CameraOverlayActive => _cameraOverlay.ShowCameraFlash || _cameraOverlay.ShowVictoryHold;
    private string? _cameraCueMessage => _cameraOverlay.CueMessage;
    private string? _cameraOverlayText => _cameraOverlay.OverlayText;
    private string ResultBannerClass => Engine.Result != GameResult.InProgress ? "show" : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlayerPrefs();
        AssignAiNamesIfNeeded();
        Engine.StartGame(_mode, _difficulty, BoardConfig);
        Engine.GameStateChanged += OnGameStateChanged;
    }

    private async Task OnGameStateChanged()
    {
        await InvokeAsync(async () =>
        {
            try
            {
                // Compute animation highlights for all modes
                ComputeSpecialHighlights();

                // Compute AI move evaluations for overlays if enabled
                if (_showAiVisualization && Engine.Result == GameResult.InProgress)
                {
                    _aiMoveEvaluations = AiPlayer.GetMoveEvaluations(Engine.Board.Clone(), Engine.CurrentPlayer, _difficulty);
                }
                else
                {
                    _aiMoveEvaluations = null;
                }

               // Play sound for win/draw and trigger shake
                if (Engine.Result != GameResult.InProgress)
                {
                    await PersistResultAsync();
                    if (_statsPanel is not null)
                        await _statsPanel.RefreshAsync();

                    if (Engine.Result == GameResult.XWins || Engine.Result == GameResult.OWins)
                    {
                        await js.InvokeVoidAsync("tttSound.play", "win");
                        ShowShake = true;
                        StateHasChanged();
                        await Task.Delay(500);
                        ShowShake = false;
                        StateHasChanged();
                    }
                    else if (Engine.Result == GameResult.Draw)
                    {
                        await js.InvokeVoidAsync("tttSound.play", "draw");
                        ShowShake = true;
                        StateHasChanged();
                        await Task.Delay(500);
                        ShowShake = false;
                        StateHasChanged();
                    }

                    if (_mode == GameMode.CvC)
                    {
                        var dramaticHold = _dramaticWinPending;
                        _cvcMoveDelay = Math.Max(CvcMinDelay, (int)(_cvcMoveDelay * CvcDecayFactor));
                        var resultLabel = Engine.Result switch
                        {
                            GameResult.XWins => GetPlayerLabel(Player.X),
                            GameResult.OWins => GetPlayerLabel(Player.O),
                            _ => "Draw"
                        };
                        _cameraOverlay.SetCueMessage($"Camera hold: {resultLabel} – next cycle {_cvcMoveDelay}ms", StateHasChanged);

                        if (dramaticHold && (Engine.Result == GameResult.XWins || Engine.Result == GameResult.OWins))
                            ShowVictoryHoldOverlay("Victory hold", $"Camera hold: {resultLabel} wins");

                        ScheduleCvcRestart(dramaticHold);
                    }
                }
                else if (_mode == GameMode.CvC)
                {
                    var lastPlayer = Engine.CurrentPlayer == Player.X ? Player.O : Player.X;
                    if (TryTriggerForkHighlight(lastPlayer))
                        _cameraOverlay.SetCueMessage($"{GetPlayerLabel(lastPlayer)} is setting up a fork", StateHasChanged);
                    _cvcScheduler.Schedule(_cvcMoveDelay, async () => Engine.TriggerAiMove());
                }
            }
            catch (Exception ex) when (ex is not OperationCanceledException)
            {
                Logger.LogError(ex, "Unhandled exception while updating game state.");
            }
            finally
            {
                StateHasChanged();
            }
        });
    }

    private void HandleVisualizationModeChanged(string mode)
    {
        _visualizationMode = mode;
        _stepIndex = 0;
        _stepPlay = false;
        StateHasChanged();
    }

    private void HandleStepIndexChanged(int index)
    {
        if (_aiMoveEvaluations is null || _aiMoveEvaluations.Count == 0) return;
        _stepIndex = Math.Max(0, Math.Min(index, _aiMoveEvaluations.Count - 1));
        StateHasChanged();
    }

    private void HandleStepPlayChanged(bool play)
    {
        _stepPlay = play;
        if (play) StartStepPlayLoop();
        StateHasChanged();
    }

    private async void StartStepPlayLoop()
    {
        while (_stepPlay && _aiMoveEvaluations != null && _stepIndex < _aiMoveEvaluations.Count - 1)
        {
            await Task.Delay(700);
            if (!_stepPlay) break;
            _stepIndex++;
            StateHasChanged();
        }
        _stepPlay = false;
        StateHasChanged();
    }

    private void HandleShowAiVisualizationChanged(bool value)
    {
        _showAiVisualization = value;
        StateHasChanged();
    }

    private void HandlePlayerXNameChanged(string name) 
    { 
        _playerXName = name; 
        _ = SavePlayerPrefs(); 
        StateHasChanged(); 
    }
    
    private void HandlePlayerONameChanged(string name) 
    { 
        _playerOName = name; 
        _ = SavePlayerPrefs(); 
        StateHasChanged(); 
    }
    
    private void HandlePlayerXColorChanged(string color) 
    { 
        _playerXColor = color; 
        _ = SavePlayerPrefs(); 
        StateHasChanged(); 
    }
    
    private void HandlePlayerOColorChanged(string color) 
    { 
        _playerOColor = color; 
        _ = SavePlayerPrefs(); 
        StateHasChanged(); 
    }

    private async Task SavePlayerPrefs()
    {
        try
        {
            var prefs = System.Text.Json.JsonSerializer.Serialize(new { _playerXName, _playerOName, _playerXColor, _playerOColor });
            await js.InvokeVoidAsync("localStorage.setItem", "ttt_player_prefs", prefs);
        }
        catch { }
    }

    private async Task LoadPlayerPrefs()
    {
        try
        {
            var prefsJson = await js.InvokeAsync<string>("localStorage.getItem", "ttt_player_prefs");
            if (!string.IsNullOrWhiteSpace(prefsJson))
            {
                var prefs = System.Text.Json.JsonSerializer.Deserialize<System.Collections.Generic.Dictionary<string, string>>(prefsJson);
                if (prefs != null)
                {
                    if (prefs.TryGetValue("_playerXName", out var xName)) _playerXName = xName;
                    if (prefs.TryGetValue("_playerOName", out var oName)) _playerOName = oName;
                    if (prefs.TryGetValue("_playerXColor", out var xColor)) _playerXColor = xColor;
                    if (prefs.TryGetValue("_playerOColor", out var oColor)) _playerOColor = oColor;
                }
            }
        }
        catch { }
    }

    private void ClearHint()
    {
        _hintIndex = null;
        _hintExplanation = null;
    }

    private void HandleHintRequested()
    {
        if (_mode != GameMode.PvC || Engine.Result != GameResult.InProgress)
            return;

        var move = AiPlayer.ChooseMove(Engine.Board.Clone(), Engine.CurrentPlayer, _difficulty);
        _hintIndex = move;
        // Explanation for Hard/Minimax
        if (_difficulty == Difficulty.Hard)
        {
            _hintExplanation = "This move is optimal (minimax).";
        }
        else if (_difficulty == Difficulty.Medium)
        {
            _hintExplanation = "This move blocks a win or creates a win if possible.";
        }
        else
        {
            _hintExplanation = "This move is chosen at random.";
        }
        StateHasChanged();
    }

    /// <summary>
    /// Computes and sets cell highlight lists for fork, block, and draw animations.
    /// </summary>
    private void ComputeSpecialHighlights()
    {
        var board = Engine.Board;
        var current = Engine.CurrentPlayer;
        var opponent = current == Player.X ? Player.O : Player.X;
        var available = board.GetAvailableMoves();

        // Fork: highlight cells that create two or more winning lines for current player
        var forkCells = new List<int>();
        foreach (var move in available)
        {
            int winCount = 0;
            var clone = board.Clone();
            clone.MakeMove(move, current);
            var result = clone.CheckResult();
            if (result == (current == Player.X ? GameResult.XWins : GameResult.OWins))
            {
                // Already a win, not a fork
                continue;
            }
            // Count how many moves after this would win
            foreach (var next in clone.GetAvailableMoves())
            {
                var forkClone = clone.Clone();
                forkClone.MakeMove(next, current);
                if (forkClone.CheckResult() == (current == Player.X ? GameResult.XWins : GameResult.OWins))
                    winCount++;
            }
            if (winCount >= 2)
                forkCells.Add(move);
        }

        // Block: highlight cells that block opponent's immediate win
        var blockCells = new List<int>();
        foreach (var move in available)
        {
            var clone = board.Clone();
            clone.MakeMove(move, opponent);
            if (clone.CheckResult() == (opponent == Player.X ? GameResult.XWins : GameResult.OWins))
                blockCells.Add(move);
        }

        // Draw: highlight all cells if game ended in draw
        IReadOnlyList<int>? drawCells = null;
        if (Engine.Result == GameResult.Draw)
            drawCells = Enumerable.Range(0, board.CellCount).ToList();

        _forkCells = forkCells.Count > 0 ? forkCells : null;
        _blockCells = blockCells.Count > 0 ? blockCells : null;
        _drawCells = drawCells;
    }

    private async Task HandleHumanMove(int index)
    {
        if (Engine.Result != GameResult.InProgress) return;
        Engine.HumanMove(index);

        // Play move sound (for human move)
        await js.InvokeVoidAsync("tttSound.play", "move");

        // PvC: after human move, trigger AI
        if (Engine.Mode == GameMode.PvC && Engine.Result == GameResult.InProgress)
            _cvcScheduler.Schedule(400, async () => Engine.TriggerAiMove());
    }

    private void HandleModeChanged(GameMode mode)
    {
        _mode = mode;
        AssignAiNamesIfNeeded();
        StartNewGame();
    }

    private void AssignAiNamesIfNeeded()
    {
        var rng = new Random();
        if (_mode == GameMode.CvC)
        {
            _playerXName = PickAiName(rng, string.Empty);
            _playerOName = PickAiName(rng, _playerXName);
        }
        else if (_mode == GameMode.PvC)
        {
            _playerXName = "Player";
            _playerOName = PickAiName(rng, string.Empty);
        }
        else
        {
            _playerXName = "Player X";
            _playerOName = "Player O";
        }
    }

    private void HandleBoardSizeChanged(int size)
    {
        if (size == _boardSize) return;
        _boardSize = size;
        StartNewGame();
    }

    private void HandleDifficultyChanged(Difficulty difficulty)
    {
        _difficulty = difficulty;
        StartNewGame();
    }

    private async void StartNewGame()
    {
        _showResetAnim = true;
        StateHasChanged();
        await Task.Delay(350);
        _showResetAnim = false;
        _cvcScheduler.Cancel();
        _cameraOverlay.Cancel();
        _resultPersisted = false;
        _cvcMoveDelay = CvcStartDelay; // reset speed on manual new game
        Engine.StartGame(_mode, _difficulty, BoardConfig);

        if (_mode == GameMode.CvC)
            _cvcScheduler.Schedule(_cvcMoveDelay, async () => Engine.TriggerAiMove());
        else if (_mode == GameMode.PvC && Engine.CurrentPlayer == Player.O)
            _cvcScheduler.Schedule(600, async () => Engine.TriggerAiMove());
    }

    private void ScheduleCvcRestart(bool dramaticHold = false)
    {
        int pauseMs = Math.Max(120, _cvcMoveDelay * 3);
        if (dramaticHold)
            pauseMs += DramaticHoldBonusMs;
        _cvcScheduler.Cancel();
        _cameraOverlay.Cancel();
        // Auto-dismiss the result banner then start the next game
        _cvcScheduler.Schedule(pauseMs, async () =>
        {
            if (_mode != GameMode.CvC)
                return;
            _resultPersisted = false;
            _cameraOverlay.Cancel();
            AssignAiNamesIfNeeded();
            Engine.StartGame(GameMode.CvC, _difficulty, BoardConfig);
            await InvokeAsync(StateHasChanged);
            _cvcScheduler.Schedule(_cvcMoveDelay, async () => Engine.TriggerAiMove());
        });
        _dramaticWinPending = false;
    }

    private void TriggerCameraFlashOverlay(string overlayText, string cueMessage)
    {
        _cameraOverlay.TriggerFlash(overlayText, cueMessage, CameraFlashDurationMs, StateHasChanged);
    }

    private void ShowVictoryHoldOverlay(string overlayText, string cueMessage)
    {
        _cameraOverlay.ShowVictory(overlayText, cueMessage, VictoryHoldDurationMs, StateHasChanged);
    }

    private bool TryTriggerForkHighlight(Player player)
    {
        if (!HasForkOpportunity(player))
            return false;

        _dramaticWinPending = true;
        TriggerCameraFlashOverlay("Strategic fork", $"{GetPlayerLabel(player)} is creating a fork");
        return true;
    }

    private bool HasForkOpportunity(Player player)
    {
        var board = Engine.Board;
        var availableMoves = board.GetAvailableMoves();
        if (availableMoves.Count < 2)
            return false;

        var winningResult = player == Player.X ? GameResult.XWins : GameResult.OWins;
        int winCount = 0;
        foreach (var move in availableMoves)
        {
            var clone = board.Clone();
            clone.MakeMove(move, player);
            if (clone.CheckResult() == winningResult)
            {
                winCount++;
                if (winCount >= 2)
                    return true;
            }
        }

        return false;
    }

    private static string GetPlayerLabel(Player player) => player == Player.X ? "X (AI)" : "O (AI)";

    private async Task PersistResultAsync()
    {
        if (_resultPersisted) return;
        _resultPersisted = true;

        switch (Engine.Result)
        {
            case GameResult.Draw:
                await StatsService.IncrementDrawAsync(_mode);
                break;
            case GameResult.XWins:
                await StatsService.IncrementWinAsync(_mode);
                break;
            case GameResult.OWins:
                await StatsService.IncrementLossAsync(_mode);
                break;
        }
    }

    public void Dispose()
    {
        Engine.GameStateChanged -= OnGameStateChanged;
        _cvcScheduler.Dispose();
        _cameraOverlay.Dispose();
    }
}
